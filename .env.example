# Backend settings
ENVIRONMENT=development
PROJECT_NAME="Raikou SAR API"
API_V1_STR=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Keep this false outside a short-lived local prototype session. Session IDs
# have no durable project ownership boundary and are never mounted in V1.
ENABLE_LEGACY_SESSION_API=false

# Server-only Supabase credentials. Never expose SUPABASE_SERVICE_KEY to React.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
# M3 workers/dispatcher only: direct PostgreSQL connection, never client-side.
SUPABASE_DB_URL=

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sar_patches

# Optional during local development. Required when ENVIRONMENT=production.
REDIS_URL=
REDIS_KEY_PREFIX=raikou:v1
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2

# M6 HTTP release controls. In production CORS must contain only the exact
# deployed React origin (for example https://app.example.com), never localhost.
MAX_API_REQUEST_BYTES=4194304
API_RATE_LIMIT_PER_MINUTE=120
UPLOAD_INITIATE_RATE_LIMIT_PER_MINUTE=12
# Keep this unset only when /metrics is reachable solely on a private network.
METRICS_TOKEN=
LOG_JSON=true

VLLM_BASE_URL=http://localhost:8001/v1
SARCHAT_MODEL_ID=/models/SARChat-InternVL2.5-2B
PRELOAD_SARCLIP=false
SARCLIP_CHECKPOINT_PATH=/models/sarclip_vit_l14.pt
# Leave blank to choose CUDA when it is available, otherwise CPU.
SARCLIP_DEVICE=
SARCLIP_BATCH_SIZE=32
SESSION_ROOT=
SESSION_TTL_HOURS=168

# M2 object storage. Development uses MinIO through the same S3-compatible
# adapter as production; set STORAGE_BACKEND=s3 and leave ENDPOINT_URL blank
# when using AWS S3. Production custom/MinIO endpoints must use HTTPS because
# browsers upload directly to presigned URLs. IAM roles can supply credentials.
# AWS_REGION and S3_BUCKET_NAME are accepted aliases for the normalized settings.
STORAGE_BACKEND=minio
STORAGE_BUCKET=raikou-dev
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900
# M4 browser previews are private one-time display grants, not durable URLs.
ARTIFACT_PREVIEW_TTL_SECONDS=90
M4_MAX_EVIDENCE_RECORD_BYTES=2097152
STORAGE_MULTIPART_CHECKSUM_MODE=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# Only needed for explicit temporary credentials. Standard AWS_* variable
# names remain accepted for backward compatibility.
STORAGE_SESSION_TOKEN=

# M2 upload-plan and archive safety limits. Each signed URL remains short
# lived, while the whole-upload plan lease is size-aware up to the absolute
# cap. Values are bytes except the ratio and time values.
UPLOAD_PLAN_TTL_SECONDS=900
UPLOAD_PLAN_MAX_TTL_SECONDS=86400
UPLOAD_PLAN_MIN_BYTES_PER_SECOND=524288
UPLOAD_COMPLETION_LEASE_SECONDS=7200
UPLOAD_MULTIPART_PART_SIZE_BYTES=16777216
UPLOAD_MAX_ARCHIVE_BYTES=21474836480
UPLOAD_MAX_RASTER_BYTES=10737418240
UPLOAD_MAX_METADATA_BYTES=1048576
UPLOAD_MAX_TOTAL_BYTES=21474836480
UPLOAD_MAX_ZIP_ENTRIES=20000
UPLOAD_MAX_ZIP_CENTRAL_DIRECTORY_BYTES=33554432
UPLOAD_MAX_ZIP_UNCOMPRESSED_BYTES=85899345920
UPLOAD_MAX_ZIP_COMPRESSION_RATIO=100
JOB_DISPATCH_LEASE_SECONDS=60
JOB_DISPATCH_RETRY_BASE_SECONDS=10
JOB_DISPATCH_RETRY_MAX_SECONDS=300

# M3 durable pipeline. Stream names are derived from REDIS_KEY_PREFIX and are
# intentionally separate from cache keys. Start GPU concurrency at one and
# increase it only after measuring SARCLIP VRAM usage on the target GPU.
M3_OUTBOX_POLL_SECONDS=1
M3_TASK_LEASE_SECONDS=300
M3_DISPATCH_LEASE_SECONDS=60
M3_STREAM_BLOCK_MILLISECONDS=5000
M3_STREAM_CLAIM_IDLE_MILLISECONDS=120000
M3_WORKER_SCRATCH_ROOT=/tmp/raikou-workers
M3_CPU_WORKER_CONCURRENCY=2
M3_GPU_INFERENCE_CONCURRENCY=1
M3_TASK_MAX_ATTEMPTS=5
M3_QDRANT_BATCH_SIZE=64
M3_MAX_PATCH_PREVIEWS=128
M3_VLLM_TIMEOUT_SECONDS=45
M3_VLLM_MAX_IMAGES=4
M3_VLLM_MAX_TOKENS=512
M3_VLLM_MAX_IMAGE_BYTES=4194304

# M5 scoped evidence search and grounded NDJSON chat. Redis values are
# tenant/project scoped derived cache entries only; PostgreSQL, S3 and Qdrant
# remain authoritative. Bump M5_QDRANT_INDEX_VERSION after payload/index work.
M5_QUERY_EMBEDDING_TTL_SECONDS=3600
M5_RETRIEVAL_TTL_SECONDS=300
M5_RAG_CONTEXT_TTL_SECONDS=120
M5_CACHE_INDEX_TTL_SECONDS=7200
M5_SEARCH_MAX_RESULTS=10
M5_WEAK_RETRIEVAL_SCORE=0.16
M5_MAX_QUERY_CHARS=1000
M5_MAX_HISTORY_MESSAGES=12
M5_MAX_HISTORY_CHARS=6000
M5_MAX_CONTEXT_CHARS=12000
M5_MAX_CONTEXT_FACTS=50
M5_MAX_OVERVIEWS_PER_PROMPT=2
M5_MAX_PATCH_IMAGES_PER_PROMPT=4
M5_MAX_IMAGE_BYTES=4194304
M5_OUTPUT_MAX_TOKENS=700
M5_GENERATION_TIMEOUT_SECONDS=75
M5_QDRANT_INDEX_VERSION=v1
