[Unit]
Description=SARChat InternVL2.5-2B vLLM server
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=simple
Restart=always
RestartSec=10
ExecStartPre=-/usr/bin/docker rm -f sarchat-vllm
ExecStart=/usr/bin/docker run --rm --name sarchat-vllm --gpus all --restart=no -v /home/ubuntu/backend/models:/models -p 127.0.0.1:8001:8000 vllm/vllm-openai:latest --model /models/SARChat-InternVL2.5-2B --trust-remote-code --gpu-memory-utilization 0.45 --max-model-len 4096 --max-num-seqs 2 --limit-mm-per-prompt {\"image\":4}
ExecStop=/usr/bin/docker stop -t 30 sarchat-vllm

[Install]
WantedBy=multi-user.target
