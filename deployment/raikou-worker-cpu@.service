[Unit]
Description=Raikou M3 CPU/IO worker %i
After=network-online.target raikou-outbox-dispatcher.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/backend
EnvironmentFile=-/home/ubuntu/backend/.env
Environment=PYTHONUNBUFFERED=1
Environment=ENVIRONMENT=production
ExecStart=/home/ubuntu/sar_env/bin/python -m app.workers.runner --class cpu
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
